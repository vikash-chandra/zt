# ==========================================
# 1. COMMON SYSTEM CONFIGURATIONS
# ==========================================

# Zerodha API Connections
KITE_API_KEY=your_api_key_here
KITE_API_SECRET=your_api_secret_here
KITE_USER_ID=your_user_id_here
KITE_ACCESS_TOKEN=your_access_token_here
KITE_REDIRECT_URL=http://localhost:8080/callback
LIVE_TRADING=false
DEFAULT_ORDER_TYPE=MARKET
SQUARE_OFF_ON_SHUTDOWN=true

# TimescaleDB & PostgreSQL Connection
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=your_password_here
DB_NAME=zerodha_trading
DB_SSL_MODE=disable
GODEBUG=netdns=go

# Global Risk Controls & Position Limits
INITIAL_CAPITAL=100000
MAX_TRADES_PER_DAY=1
MAX_LOSS_STREAKS=3
MAX_HOLDING_TIME_MIN=360
MAX_CAPITAL_PER_TRADE=2000.0
MAX_DAILY_LOSS_AMOUNT=2500.0
GLOBAL_TRADE_START_TIME=09:15
# Watchlist size limit per strategy (each strategy selects up to this many stocks, then they are merged)
STRATEGY_WATCHLIST_SIZE=10
MANUAL_BIAS_CUTOFF=10:38
MANUAL_WATCHLIST_CUTOFF=09:25
STOCK_SELECT_TIME=09:25

# Monitoring & Logging Metrics
LOG_LEVEL=info

# Active Strategy Selection
ACTIVE_STRATEGIES=LOW_VOLUME,VANDE_BHARAT
ACTIVE_SELECTORS=SECURITIES_FO,SECTORAL
STRATEGY_SELECTOR_MAP=LOW_VOLUME:SECURITIES_FO,VANDE_BHARAT:SECTORAL
RISK_REWARD_TYPE=STANDARD
RISK_REWARD_RATIO=2.0

# ==========================================
# 2. LOW_VOLUME STRATEGY PARAMETERS
# ==========================================
LV_SL_BUFFER_PCT=10.0
LV_WATCHLIST_MAX_PCT_CHANGE=2.5
LV_TRADE_START_TIME=09:30
LV_TRADE_END_TIME=12:59
# If true, places a hard Stop-Loss (SL/SL-M) order directly on the broker's system. If false, tracks SL internally (soft SL) and triggers exits via market orders.
LV_USE_BROKER_SL=true

# ==========================================
# 3. VANDE_BHARAT STRATEGY PARAMETERS
# ==========================================
VB_SL_BUFFER_PCT=10.0
VB_SECTOR_MAX_BUY_PCT=2.5
VB_SECTOR_MAX_SELL_PCT=-3.0
VB_STOCK_MAX_BUY_PCT=2.5
VB_STOCK_MAX_SELL_PCT=-2.5
VB_MASTER_MAX_PCT=3.0
VB_CONFIRM_MAX_PCT=1.0
VB_TRADE_START_TIME=09:25
VB_TRADE_END_TIME=12:59
# If true, places a hard Stop-Loss (SL/SL-M) order directly on the broker's system. If false, tracks SL internally (soft SL) and triggers exits via market orders.
VB_USE_BROKER_SL=true
