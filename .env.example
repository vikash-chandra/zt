# Zerodha API Configuration
KITE_API_KEY=your_api_key_here
KITE_API_SECRET=your_api_secret_here
KITE_USER_ID=your_user_id_here
KITE_ACCESS_TOKEN=your_access_token_here
KITE_REDIRECT_URL=http://localhost:8080/callback

# Database Configuration (PostgreSQL + TimescaleDB)
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=your_password_here
DB_NAME=zerodha_trading
DB_SSL_MODE=disable

# Redis Cache
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Trading Parameters
INITIAL_CAPITAL=500000
MAX_DAILY_LOSS_PCT=2.0
MAX_LOSS_AMOUNT=10000
MAX_POSITION_SIZE=100000
MAX_TRADES_PER_DAY=20
MAX_LOSS_STREAKS=3
MAX_QTY_PER_ORDER=5000
MIN_PROFIT_TARGET_PCT=0.5
MAX_HOLDING_TIME_MIN=30

# Monitoring & Logging
LOG_LEVEL=info
PROMETHEUS_ADDR=:8888
